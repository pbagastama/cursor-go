# Alamat backend proxy Cursor yang dipakai frontend.
# Default (dev lokal): http://localhost:8787/v1
# Produksi (contoh): https://cursorgo-backend.onrender.com/v1
VITE_CURSOR_PROXY_URL=http://localhost:8787/v1

# Opsional — origin backend tanpa /v1 (untuk upload ZIP).
# Kalau kosong, diturunkan dari VITE_CURSOR_PROXY_URL.
# VITE_API_BASE_URL=http://localhost:8787

# Backend (server/index.mjs)
# CURSOR_API_KEY=key_xxxxxxxxxxxxxxxx
# PORT=8787
# ALLOWED_ORIGINS=http://localhost:5173,https://cursor-go.netlify.app
# URL frontend publik — dipakai untuk shareUrl /zip/:id
# PUBLIC_FRONTEND_URL=https://cursor-go.netlify.app
# ZIP_MAX_BYTES=83886080
