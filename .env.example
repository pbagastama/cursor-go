# Alamat backend proxy Cursor yang dipakai frontend.
# Default (dev lokal): http://localhost:8787/v1
# Saat deploy di Netlify tapi backend tetap di laptopmu, biarkan localhost:
VITE_CURSOR_PROXY_URL=http://localhost:8787/v1

# Backend (server/index.mjs) — opsional, bisa juga isi key lewat UI Settings.
# CURSOR_API_KEY=key_xxxxxxxxxxxxxxxx
# PORT=8787
